@model SmartHrSystem.ViewModels.RoleViewModel

@{
    ViewData["Title"] = "Add Role";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted small">
        &larr; Roles
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">Add new role</h5>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">
                            Role title <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title"
                               class="form-control"
                               placeholder="e.g. Developer" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label">
                            Description <span class="text-muted small">(optional)</span>
                        </label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Brief description of this role"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <hr />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save role</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>