@model IEnumerable<SmartHrSystem.Models.Employee>

@{
    ViewData["Title"] = "Employees Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark font-weight-bold m-0">Employees List</h2>
        <a asp-action="Create" class="btn btn-primary px-4 py-2">
            <i class="fas fa-plus mr-1"></i> Add New Employee
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="border-0 py-3">Full Name</th>
                            <th class="border-0 py-3">Email</th>
                            <th class="border-0 py-3">Phone</th>
                            <th class="border-0 py-3">Department</th>
                            <th class="border-0 py-3">Role</th>
                            <th class="border-0 py-3">Salary</th>
                            <th class="border-0 py-3 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">No employees found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="py-3 font-weight-bold">@item.FirstName @item.LastName</td>
                                    <td class="py-3">@item.Email</td>
                                    <td class="py-3">@item.Phone</td>
                                    <td class="py-3"><span class="badge bg-primary text-white px-2 py-1">@item.Department?.Name</span></td>
                                    <td class="py-3"><span class="badge bg-secondary text-white px-2 py-1">@item.Role?.Title</span></td>
                                    <td class="py-3 font-weight-bold text-success">$@item.Salary.ToString("N0")</td>
                                    <td class="py-3 text-center">
                                        <div class="d-flex justify-content-center">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info mr-2">Edit</a>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this employee?');" style="display:inline;">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>