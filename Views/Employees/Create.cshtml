@model SmartHrSystem.ViewModels.EmployeeFormViewModel

@{
    ViewData["Title"] = "Add Employee";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted small">
        &larr; Employees
    </a>
</div>

<div class="row">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-1">Add new employee</h5>
                <p class="text-muted small mb-4">
                    This will create an employee record and a portal login account.
                </p>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    @* ── Personal Info ── *@
                    <h6 class="fw-semibold text-muted mb-3 border-bottom pb-2">
                        Personal information
                    </h6>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label">
                                First name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="FirstName" class="form-control" placeholder="Sara" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label">
                                Last name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="LastName" class="form-control" placeholder="Ahmed" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">
                                Email <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Email" class="form-control"
                                   placeholder="sara@company.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label">Phone</label>
                            <input asp-for="Phone" class="form-control"
                                   placeholder="+20 100 000 0000" />
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label asp-for="HireDate" class="form-label">
                                Hire date <span class="text-danger">*</span>
                            </label>
                            <input asp-for="HireDate" type="date" class="form-control" />
                            <span asp-validation-for="HireDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DepartmentId" class="form-label">
                                Department <span class="text-danger">*</span>
                            </label>
                            <select asp-for="DepartmentId"
                                    asp-items="Model.Departments"
                                    class="form-select">
                                <option value="">Select department</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="RoleId" class="form-label">
                                Role <span class="text-danger">*</span>
                            </label>
                            <select asp-for="RoleId"
                                    asp-items="Model.Roles"
                                    class="form-select">
                                <option value="">Select role</option>
                            </select>
                            <span asp-validation-for="RoleId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Salary" class="form-label">
                            Salary <span class="text-danger">*</span>
                        </label>
                        <div class="input-group">
                            <input asp-for="Salary" class="form-control" placeholder="0" />
                            <span class="input-group-text">EGP</span>
                        </div>
                        <span asp-validation-for="Salary" class="text-danger small"></span>
                    </div>

                    @* ── Portal Account ── *@
                    <h6 class="fw-semibold text-muted mb-3 border-bottom pb-2">
                        Portal login account
                    </h6>
                    <p class="text-muted small mb-3">
                        The employee will use their email and this password to log in.
                    </p>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label">
                                Password <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="Min 6 characters" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label">
                                Confirm password <span class="text-danger">*</span>
                            </label>
                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Repeat password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    @* general identity errors *@
                    @if (!ViewData.ModelState.IsValid)
                    {
                        foreach (var error in ViewData.ModelState[""]?.Errors ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.ModelBinding.ModelError>())
                        {
                            <div class="alert alert-danger py-2">@error.ErrorMessage</div>
                        }
                    }

                    <hr />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            Save employee
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>