@model SmartHrSystem.ViewModels.MyAttendanceViewModel

@{
    ViewData["Title"] = "My Attendance";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0">My Attendance</h5>
        <p class="text-muted small mb-0">Your full attendance history.</p>
    </div>
    <a asp-action="RecordAttendance" class="btn btn-primary btn-sm">
        + Record today
    </a>
</div>

@* summary cards *@
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm border-start border-success border-4">
            <div class="card-body">
                <p class="text-muted small mb-1">Present</p>
                <h4 class="fw-bold mb-0">@Model.PresentCount</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm border-start border-warning border-4">
            <div class="card-body">
                <p class="text-muted small mb-1">Late</p>
                <h4 class="fw-bold mb-0">@Model.LateCount</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm border-start border-secondary border-4">
            <div class="card-body">
                <p class="text-muted small mb-1">On leave</p>
                <h4 class="fw-bold mb-0">@Model.OnLeaveCount</h4>
            </div>
        </div>
    </div>
</div>

@* records table *@
<div class="card border-0 shadow-sm">
    @if (!Model.Records.Any())
    {
        <div class="card-body text-center py-5 text-muted">
            No attendance records yet.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Check-in</th>
                        <th>Check-out</th>
                        <th>Status</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in Model.Records)
                    {
                        <tr>
                            <td>@record.Date.ToString("MMM dd, yyyy")</td>
                            <td>@record.CheckIn.ToString("hh:mm tt")</td>
                            <td>
                                @(record.CheckOut.HasValue
                                                        ? record.CheckOut.Value.ToString("hh:mm tt")
                                                        : "—")
                    </td>
                    <td>
                        @{
                                    var badgeClass = record.Status switch
                                    {
                                        "Present" => "bg-success",
                                        "Late" => "bg-warning text-dark",
                                        "On Leave" => "bg-secondary",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass rounded-pill">
                                    @record.Status
                                </span>
                            </td>
                            <td class="text-muted">
                                @(string.IsNullOrEmpty(record.Notes) ? "—" : record.Notes)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>