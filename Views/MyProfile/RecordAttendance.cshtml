@model SmartHrSystem.ViewModels.RecordAttendanceViewModel

@{
    ViewData["Title"] = "Record Attendance";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="mb-4">
    <a asp-action="Attendance" class="text-decoration-none text-muted small">
        &larr; My Attendance
    </a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-1">Record today's attendance</h5>
                <p class="text-muted small mb-4">
                    @DateTime.Today.ToString("dddd, MMM dd yyyy")
                </p>

                <form asp-action="RecordAttendance" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">
                            Check-in time <span class="text-danger">*</span>
                        </label>
                        <input asp-for="CheckIn"
                               type="time"
                               class="form-control" />
                        <span asp-validation-for="CheckIn" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Check-out time
                            <span class="text-muted small">(optional)</span>
                        </label>
                        <input asp-for="CheckOut"
                               type="time"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Status <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Status" class="form-select">
                            <option value="Present">Present</option>
                            <option value="Late">Late</option>
                            <option value="On Leave">On Leave</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">
                            Notes <span class="text-muted small">(optional)</span>
                        </label>
                        <textarea asp-for="Notes"
                                  class="form-control"
                                  rows="2"
                                  placeholder="Any notes..."></textarea>
                    </div>

                    <hr />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save record</button>
                        <a asp-action="Attendance" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>