@model SmartHrSystem.ViewModels.MyProfileViewModel

@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<div class="mb-4">
    <h5 class="fw-bold mb-0">My Profile</h5>
    <p class="text-muted small">Your personal information on record.</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-primary text-white py-3">
                <h6 class="mb-0 fw-bold">@Model.FullName</h6>
                <small class="opacity-75">@Model.Role — @Model.Department</small>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr class="border-bottom">
                            <td class="text-muted fw-semibold" style="width:140px;">Email</td>
                            <td>@Model.Email</td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="text-muted fw-semibold">Phone</td>
                            <td>@(string.IsNullOrEmpty(Model.Phone) ? "—" : Model.Phone)</td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="text-muted fw-semibold">Department</td>
                            <td>@Model.Department</td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="text-muted fw-semibold">Role</td>
                            <td>@Model.Role</td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="text-muted fw-semibold">Salary</td>
                            <td class="fw-semibold text-success">
                                @Model.Salary.ToString("N0") EGP
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold">Hire date</td>
                            <td>@Model.HireDate.ToString("MMM dd, yyyy")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>