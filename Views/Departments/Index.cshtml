@model IEnumerable<SmartHrSystem.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0 fw-bold">Departments</h5>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        + Add department
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <p class="mb-2">No departments found.</p>
            <a asp-action="Create" class="btn btn-primary btn-sm">Add your first department</a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th class="text-center">Employees</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dept in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@dept.Name</td>
                            <td class="text-muted">
                                @(string.IsNullOrEmpty(dept.Description) ? "—" : dept.Description)
                            </td>
                            <td class="text-center">
                                <span class="badge bg-primary rounded-pill">
                                    @dept.Employees.Count
                                </span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit"
                                   asp-route-id="@dept.Id"
                                   class="btn btn-outline-primary btn-sm me-1">
                                    Edit
                                </a>

                                @if (dept.Employees.Any())
                                {
                                    <button class="btn btn-sm btn-outline-secondary"
                                            disabled
                                            title="Cannot delete: department has employees assigned.">
                                        Delete
                                    </button>
                                }
                                else
                                {
                                    <form asp-action="Delete"
                                          asp-route-id="@dept.Id"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete \'@dept.Name\'?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <p class="text-muted small mt-2">
        Delete is disabled for departments that still have employees assigned.
    </p>
}